---
import Sidebar from '../components/Sidebar.astro';
import TocSidebar, { type TocHeading } from '../components/TocSidebar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  chapterTitle?: string;
  activeChapter?: string;
  activeSection?: string;
  headings?: TocHeading[];
}

const { title, description, activeChapter, activeSection, headings } =
  Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? 'CAB 软件开发规范文档'} />
    <title>{title} · CAB Spec</title>
  </head>
  <body>
    <div class="site-shell">
      <Sidebar activeChapter={activeChapter} activeSection={activeSection} />
      <main class="main">
        <slot />
      </main>
      <TocSidebar headings={headings} />
    </div>
  </body>
</html>
