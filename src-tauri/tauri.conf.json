{
  "productName": "cab-desktop",
  "version": "0.6.0",
  "identifier": "com.cab.gateway",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node -e \"const fs = require('fs'); const path = require('path'); const url = require('url'); const script = fs.existsSync('./scripts/pre-build.js') ? './scripts/pre-build.js' : '../scripts/pre-build.js'; import(url.pathToFileURL(path.resolve(script)));\""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CAB — Coding Agents Bridge",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../resources/bin/*"],
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/cab": "../target/release/cab",
          "/usr/bin/cabd": "../target/release/cabd"
        }
      }
    },
    "windows": {
      "wix": {
        "language": {
          "en-US": {
            "localePath": "./wix/locales/en-US.wxl"
          },
          "zh-CN": {
            "localePath": "./wix/locales/zh-CN.wxl"
          }
        }
      },
      "nsis": {
        "languages": ["English", "SimpChinese"],
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
